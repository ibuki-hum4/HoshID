# Kubernetes デプロイメント用の本番環境設定

# 必須設定（変更してください）
PORT=3000
NODE_ENV=production

# ドメイン設定（環境に応じて変更）
NEXT_PUBLIC_APP_URL=https://hoshid.example.com

# PostgreSQL 接続文字列
# クラウド環境の場合:
# DATABASE_URL=postgres://user:pass@db-hostname:5432/hoshid?sslmode=require
# K8s 内部 DNS の場合:
# DATABASE_URL=postgres://user:pass@db-service.hoshid.svc.cluster.local:5432/hoshid?sslmode=require

# Better Auth シークレット（32文字以上のランダム文字列に変更）
# 生成例: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-min-32-chars-here-change-me-now

# OIDC JWT 署名鍵（必須）
# /api/auth/jwks (JWKS) と OIDC ID/アクセストークンの署名・検証に使用する。
# 未設定だと JWKS が常に空集合になり、発行したトークンを誰も検証できない。
# 生成方法: cd frontend && node scripts/generate-oidc-jwk.mjs
# 出力されたJSONを1行のまま設定する（鍵をローテーションする場合は
# 現行鍵を OIDC_JWK_PREVIOUS に退避してから OIDC_JWK_CURRENT を新鍵に差し替える）。
OIDC_JWK_CURRENT={"id":"...","publicKey":"...","privateKey":"...","alg":"EdDSA","crv":"Ed25519","createdAt":"..."}
# OIDC_JWK_PREVIOUS=

# OIDC トークンの audience（未設定時は "hoshid-go-api"）
OIDC_AUDIENCE=hoshid-go-api

# SMTP（メールアドレス確認・パスワードリセットの送信に使用。実質必須）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM=noreply@hoshid.example.com
# 自己署名証明書を使う開発環境専用のメールキャッチャー以外では "true" のままにする
SMTP_TLS_REJECT_UNAUTHORIZED=true

# 任意: Go API 等の外部クライアントを動的登録するブートストラップAPI
# (/api/admin/oauth/clients/go) の認証トークン。未設定時は当該APIが常に401を返す。
# OIDC_ADMIN_BOOTSTRAP_TOKEN=your-bootstrap-token-min-32-chars-change-me

# 任意: 信頼済みOIDCクライアント（Go API）を1件だけ登録する場合
# OIDC_GO_CLIENT_ID=hoshid-go-api
# OIDC_GO_CLIENT_SECRET=
# OIDC_GO_REDIRECT_URLS=https://go-api.example.com/oauth/callback
# OIDC_GO_SKIP_CONSENT=true
# OIDC_GO_CLIENT_NAME=Go API
# 複数クライアントを登録する場合は OIDC_TRUSTED_CLIENTS_JSON にJSON配列を設定する
# （指定時は OIDC_GO_* は無視される）

# 任意: ソーシャルログイン（設定したプロバイダのみ有効化される）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# 追加の環境変数
TZ=Asia/Tokyo

