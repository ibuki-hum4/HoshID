# Kubernetes デプロイメント用の本番環境設定

# 必須設定（変更してください）
PORT=3000
NODE_ENV=production

# ドメイン設定（環境に応じて変更）
NEXT_PUBLIC_APP_URL=https://hoshid.example.com

# PostgreSQL 接続文字列
# クラウド環境の場合:
# DATABASE_URL=postgres://user:pass@db-hostname:5432/hoshid?sslmode=require
# K8s 内部 DNS の場合:
# DATABASE_URL=postgres://user:pass@db-service.hoshid.svc.cluster.local:5432/hoshid?sslmode=require

# Better Auth シークレット（32文字以上のランダム文字列に変更）
# 生成例: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-min-32-chars-here-change-me-now

# 追加の環境変数
LOG_LEVEL=info
TZ=Asia/Tokyo

